# NetSuite TBA credentials. Copy this file to `.env` and fill in the four
# secrets generated during Phase 4. .env is gitignored — never commit it.

NETSUITE_ACCOUNT_ID=6617070

# From Phase 4b (Integration record — shown once on save)
NETSUITE_CONSUMER_KEY=
NETSUITE_CONSUMER_SECRET=

# From Phase 4d (Access Token — shown once on save)
NETSUITE_TOKEN_ID=
NETSUITE_TOKEN_SECRET=

# From Phase 3 (Script + Deployment)
NETSUITE_SCRIPT_ID=3855
NETSUITE_DEPLOY_ID=1

# Saved-search internal IDs (informational; not read by the smoke test —
# pass the ID as the CLI arg)
# 3062 = GC - How Much Coffee to Roast?
# 3083 = GC - How Much Coffee to Package
# 3084 = GC - Coffee Inventory

# ---------------------------------------------------------------------------
# Dashboard / Postgres (Phase 6+)
# ---------------------------------------------------------------------------

# Neon Postgres connection strings (Vercel's native Neon integration sets
# both automatically; locally, run `vercel env pull .env`).
#  - DATABASE_URL          → pooled (use in serverless functions / app code)
#  - DATABASE_URL_UNPOOLED → direct (use for migrations / DDL)
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Shared password for the dashboard (single-tenant team auth).
DASHBOARD_PASSWORD=

# Cron handler authorization. Vercel Cron sends this as a Bearer token on the
# Authorization header so /api/refresh can reject anything that isn't cron.
CRON_SECRET=
